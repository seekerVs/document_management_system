rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }


    function isValidEmail(email) {
      return email is string && email.matches('.*@.*\\..*');
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    // Each user can only read/write their own profile

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['name', 'email', 'role', 'createdAt', 'updatedAt'])
        && isValidEmail(request.resource.data.email);
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['email', 'createdAt']);
      allow delete: if false;
    }

    // ─── Folders ─────────────────────────────────────────────────────────────
    // Owners can CRUD their own folders

    match /folders/{folderId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerUid', 'name', 'itemCount', 'createdAt', 'updatedAt']);
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerUid', 'createdAt']);
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // ─── Documents ───────────────────────────────────────────────────────────
    // Owner: full access
    // Signers: read-only (checked via signature_requests)

    match /documents/{documentId} {
      allow read: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid
        || (request.auth.token.email != null && request.auth.token.email.lower() in resource.data.authorizedEmails)
      );
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerUid', 'name', 'fileUrl', 'fileType', 'fileSizeMB', 'status', 'createdAt', 'updatedAt']);
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerUid', 'createdAt']);
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // ─── Signature Requests ──────────────────────────────────────────────────
    // Requester: full access
    // Signers (by UID): read + update their own signer entry only

    match /signature_requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.requestedByUid == request.auth.uid
        || isNamedSigner(resource.data)
      );
      allow create: if isSignedIn()
        && request.resource.data.requestedByUid == request.auth.uid
        && request.resource.data.keys().hasAll(['documentId', 'requestedByUid', 'signers', 'status', 'createdAt']);
      allow update: if isSignedIn() && (
        resource.data.requestedByUid == request.auth.uid
        || isNamedSigner(resource.data)
      );
      allow delete: if isSignedIn() && resource.data.requestedByUid == request.auth.uid;
    }

    // ─── Signing Tokens (guest signers) ──────────────────────────────────────
    // Only Cloud Functions should write here; guests read via token lookup

    match /signing_tokens/{tokenId} {
      allow read: if true; // public read — token is secret by obscurity (UUID)
      allow write: if false; // Cloud Functions only
    }

    // ─── Activities ──────────────────────────────────────────────────────────
    // Users can read their own activity; Cloud Functions write

    match /activities/{activityId} {
      allow read: if isSignedIn() && (
        resource.data.actorUid == request.auth.uid ||
        (
          resource.data.documentId != null &&
          (
            get(/databases/$(database)/documents/documents/$(resource.data.documentId)).data.ownerUid == request.auth.uid ||
            (request.auth.token.email != null && request.auth.token.email.lower() in get(/databases/$(database)/documents/documents/$(resource.data.documentId)).data.authorizedEmails)
          )
        )
      );
      allow create: if isSignedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Notifications ───────────────────────────────────────────────────────
    // Users can read + mark-as-read their own notifications

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if false;
    }

    // ─── Helper functions ────────────────────────────────────────────────────

    function isNamedSigner(data) {
      // Returns true if current user's email is in signerEmails
      // We rely on signerEmails list for collection-wide query safety
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() in data.signerEmails)
      );
    }
  }
}
